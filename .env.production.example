# Production Environment Variables for Backend
# Copy this to .env and fill in your actual values
# NEVER commit the actual .env file with real secrets

PORT=5000

# Database
MONGODB_URI=mongodb+srv://admin:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/prameela-boutique?retryWrites=true&w=majority

# Authentication
JWT_SECRET=generate_a_random_64_character_string_here_using_openssl_rand_hex_32
JWT_REFRESH_SECRET=generate_another_random_64_character_string_here_using_openssl_rand_hex_32

# CORS & Frontend
FRONTEND_URL=https://www.your-domain.com
CORS_ORIGIN=https://www.your-domain.com

# Environment
NODE_ENV=production

# Cloudinary (Image Hosting)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Email (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_specific_password
SMTP_FROM=Prameela Boutique <your_email@gmail.com>
PASSWORD_RESET_OTP_TTL_MINUTES=10
PASSWORD_RESET_TOKEN_TTL_MINUTES=15
PASSWORD_RESET_MAX_OTP_ATTEMPTS=5

# Logging (Optional)
LOG_LEVEL=info
